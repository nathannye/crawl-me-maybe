{
  "name": "crawl-me-maybe",
  "version": "1.0.0",
  "author": "Nathan Nye <nathan@nye.dev> (https://nye.dev)",
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run build:packages",
    "build:packages": "bun run --filter '*' build",
    "prepare": "husky",
    "precommit": "lint-staged",
    "postversion": "bun run build:packages && git add . && git commit --amend --no-edit",
    "version:patch": "npm version patch",
    "version:minor": "npm version minor",
    "version:major": "npm version major"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.2",
    "@types/bun": "^1.3.14",
    "@types/node": "^24.8.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.6",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "biome check --write"
    ],
    "*.{json,md,css}": [
      "biome lint --write"
    ]
  }
}
