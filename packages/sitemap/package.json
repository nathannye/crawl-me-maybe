{
  "name": "@crawl-me-maybe/sitemap",
  "version": "0.0.10",
  "sideEffects": false,
  "author": "Nathan Nye <nathan@nye.dev> (https://nye.dev)",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && bun build src/index.ts --outdir dist --format esm --sourcemap && tsc -p tsconfig.json --declaration --emitDeclarationOnly --declarationDir dist --rootDir src"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^22.10.1"
  }
}
