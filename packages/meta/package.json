{
	"name": "@crawl-me-maybe/meta",
	"version": "0.1.2",
	"sideEffects": false,
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./next": {
			"types": "./dist/next.d.ts",
			"import": "./dist/next.js"
		},
		"./nuxt": {
			"types": "./dist/nuxt.d.ts",
			"import": "./dist/nuxt.js"
		}
	},
	"publishConfig": {
		"access": "public"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"lint": "biome check .",
		"fix": "biome check --write .",
		"build": "bun run build.ts && tsc -p tsconfig.json --declaration --emitDeclarationOnly --declarationDir dist --rootDir src"
	},
	"dependencies": {
		"zhead": "^2.2.4"
	},
	"peerDependencies": {
		"next": ">=14"
	},
	"peerDependenciesMeta": {
		"next": {
			"optional": true
		}
	},
	"devDependencies": {
		"next": "^15.0.0"
	}
}
