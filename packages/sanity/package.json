{
  "name": "@crawl-me-maybe/sanity",
  "version": "0.0.6",
  "author": "Nathan Nye",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun run build.ts && tsc -p tsconfig.json --declaration --emitDeclarationOnly --declarationDir dist --rootDir src --noCheck"
  },
  "dependencies": {
    "@sanity-image/url-builder": "^1.0.0",
    "@sanity/ui": "^3.1.11",
    "@types/react": "^19.2.7",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.5.0",
    "sanity": "^4.21.1"
  },
  "devDependencies": {}
}
