{
	"name": "@crawl-me-maybe/schema",
	"version": "0.1.0",
	"type": "module",
	"author": "Nathan Nye <nathan@nye.dev> (https://nye.dev)",
	"license": "MIT",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"publishConfig": {
		"access": "public"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"lint": "biome check .",
		"fix": "biome check --write .",
		"build": "rm -rf dist && bun build src/index.ts --outdir dist --format esm --sourcemap --external schema-dts && tsc -p tsconfig.json --declaration --emitDeclarationOnly --declarationDir dist --rootDir src"
	},
	"dependencies": {
		"schema-dts": "^1.1.5"
	},
	"devDependencies": {}
}
